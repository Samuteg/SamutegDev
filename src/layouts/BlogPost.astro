---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import NoiseBackground from "../components/NoiseBackground.astro";
import ScrollProgress from "../components/ScrollProgress.astro";

type Props = CollectionEntry<"blog">["data"] & { id?: string };

const { id, title, description, pubDate, updatedDate, heroImage } = Astro.props;
const isAboutPage = Astro.url.pathname.includes("/about") || title === "Sobre";
---

<html lang="pt-BR">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 680px;
				margin: 0 auto;
				padding: 3rem 1.5rem 5rem 1.5rem;
			}

            .back-link-wrapper {
                margin-bottom: 2rem;
            }

			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.9rem;
				font-weight: 500;
				color: var(--text-muted);
			}

			.back-link:hover {
				color: var(--text-color);
			}

			article {
				background-color: transparent;
			}

			.hero-image {
				width: 100%;
				margin-bottom: 2.5rem;
				border-radius: var(--border-radius-md);
				overflow: hidden;
				border: 1px solid var(--card-border);
			}

			.hero-image img {
				width: 100%;
				height: auto;
				display: block;
			}

            .title-section {
                margin-bottom: 2.5rem;
            }

			.post-meta {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin-bottom: 1rem;
				font-family: var(--font-mono);
				font-size: 0.85rem;
				color: var(--text-muted);
			}

			.title-section h1 {
				font-size: 2.25rem;
				margin: 0;
				line-height: 1.2;
				font-weight: 800;
				letter-spacing: -0.04em;
				color: var(--text-color);
			}

			.last-updated-on {
				font-style: italic;
				color: var(--text-muted);
				font-size: 0.85rem;
				margin-top: 0.5rem;
				font-family: var(--font-mono);
			}

            /* ── Prose (Rich content) ── */
            .prose {
                color: var(--text-color);
                line-height: 1.7;
                font-size: 1.05rem;
            }

            .prose :global(h2) {
                margin-top: 3rem;
                margin-bottom: 1rem;
                padding-bottom: 0.5rem;
                font-size: 1.5rem;
                border-bottom: 1px solid var(--card-border);
            }

            .prose :global(h3) {
                margin-top: 2rem;
                margin-bottom: 0.75rem;
                font-size: 1.2rem;
            }

            .prose :global(a) {
                color: var(--text-color);
                text-decoration: underline;
                text-decoration-color: var(--card-border);
                text-underline-offset: 4px;
                transition: text-decoration-color var(--transition-fast);
            }

            .prose :global(a:hover) {
                text-decoration-color: var(--text-color);
            }

            .prose :global(ul),
            .prose :global(ol) {
                padding-left: 1.5rem;
                margin-bottom: 1.5rem;
            }

            .prose :global(li) {
                margin-bottom: 0.5rem;
            }

            .prose :global(strong) {
                color: var(--text-color);
                font-weight: 600;
            }

            .prose :global(table) {
                width: 100%;
                border-collapse: collapse;
                margin: 2rem 0;
                font-size: 0.95rem;
            }

            .prose :global(th) {
                border-bottom: 1px solid var(--card-border);
                padding: 0.75rem 1rem;
                text-align: left;
                font-weight: 600;
                color: var(--text-color);
            }

            .prose :global(td) {
                padding: 0.75rem 1rem;
                border-bottom: 1px solid var(--card-border);
                color: var(--text-muted);
            }

			@media (max-width: 768px) {
				main {
					padding: 1.5rem 1rem 3rem 1rem;
				}
				.title-section h1 {
					font-size: 1.85rem;
				}
				.prose {
					font-size: 1rem;
				}
			}
		</style>
	</head>

    <body>
        <Header />
        <NoiseBackground />
        {!isAboutPage && <ScrollProgress />}
        <main>
            {
                !isAboutPage && (
                    <div class="back-link-wrapper fade-in-up">
                        <a href="/blog" class="back-link">
                            ← Voltar
                        </a>
                    </div>
                )
            }
            <article class="fade-in-up delay-1">
                <div class="title-section">
                    {
                        !isAboutPage && (
                            <div class="post-meta">
                                <FormattedDate date={pubDate} />
                                <span class="meta-separator">•</span>
                                <span id="reading-time">Leitura</span>
                            </div>
                        )
                    }
                    <h1 style={`view-transition-name: title-${id}`}>{title}</h1>
                    {
                        updatedDate && !isAboutPage && (
                            <div class="last-updated-on">
                                Atualizado em{" "}
                                <FormattedDate date={updatedDate} />
                            </div>
                        )
                    }
                </div>
                {
                    heroImage && (
                        <div class="hero-image">
                            <Image
                                width={1020}
                                height={510}
                                src={heroImage}
                                alt=""
                                style={`view-transition-name: img-${id}`}
                            />
                        </div>
                    )
                }
                <div class="prose" id="prose-content">
                    <slot />
                </div>
            </article>
        </main>

        <Footer />

        <script src="/scripts/reading-time.js"></script>
    </body>
</html>
