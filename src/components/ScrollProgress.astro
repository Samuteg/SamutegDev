---
/**
 * ScrollProgress: A reading progress bar fixed at the top of the viewport.
 * Smoothly fills with an animated gradient as the user scrolls down.
 ---
<div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>

<!-- Scroll progress script (inline to satisfy Astro 7) -->
<script is:inline src="/scripts/scroll-progress.js"></script>

<style>
    .scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        width: 0%;
        height: 2px;
        background: linear-gradient(90deg, var(--accent-color), #6366f1);
        z-index: 100;
        transition: width 0.1s linear;
    }
</style>
