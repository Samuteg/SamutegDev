---
// Comment form with AJAX, honeypot, and success/error handling
// Formspree endpoint: https://formspree.io/f/mgojzqob
---

<section class="comment-section">
    <h2>Deixe um comentário</h2>

    <form
        id="comment-form"
        method="POST"
        action="https://formspree.io/f/mgojzqob"
        class="comment-form"
        data-netlify="true"
        novalidate
    >
        <!-- Honeypot field (hidden from humans, filled by bots) -->
        <input
            type="checkbox"
            name="_gotcha"
            id="comment-gotcha"
            tabindex="-1"
            autocomplete="off"
            style="display:none !important; position:absolute; left:-9999px;"
        />

        <!-- Redirect after successful submit (Formspree will redirect here) -->
        <input type="hidden" name="_next" value="/obrigado-comentario" />

        <label>
            Nome
            <input type="text" name="name" required aria-required="true" />
        </label>

        <label>
            Email (não será exibido)
            <input type="email" name="email" required aria-required="true" />
        </label>

        <label>
            Comentário
            <textarea name="message" rows="4" required aria-required="true"
            ></textarea>
        </label>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary" id="comment-submit">
                <span class="btn-text">Enviar</span>
                <span class="btn-loading" hidden>Enviando…</span>
            </button>
        </div>

        <!-- Status messages (injected by JS) -->
        <div id="comment-status" class="comment-status" aria-live="polite">
        </div>
    </form>

    <!-- Lista de comentários existentes (placeholder para futuras integrações) -->
    <div class="comments-list" id="comments-list">
        <p class="comments-empty">Seja o primeiro a comentar!</p>
    </div>
</section>

<style>
    .comment-section {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--card-border);
    }
    .comment-section h2 {
        font-size: 1.5rem;
        margin-bottom: 1rem;
    }
    .comment-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .comment-form label {
        display: flex;
        flex-direction: column;
        font-size: 0.9rem;
        color: var(--text-muted);
    }
    .comment-form input,
    .comment-form textarea {
        padding: 0.5rem;
        border: 1px solid var(--card-border);
        border-radius: var(--border-radius-sm);
        font-family: var(--font-sans);
        font-size: 0.9rem;
        background: var(--bg-subtle);
        color: var(--text-color);
        transition: border-color var(--transition-fast);
    }
    .comment-form input:focus,
    .comment-form textarea:focus {
        outline: none;
        border-color: var(--accent-color);
    }
    .comment-form input[aria-invalid="true"],
    .comment-form textarea[aria-invalid="true"] {
        border-color: #dc2626; /* red-600 */
    }
    .form-actions {
        display: flex;
        gap: 0.5rem;
    }
    .btn-loading {
        display: none;
    }
    .btn:disabled .btn-text {
        display: none;
    }
    .btn:disabled .btn-loading {
        display: inline;
    }

    /* Status messages */
    .comment-status {
        padding: 0.75rem 1rem;
        border-radius: var(--border-radius-sm);
        font-size: 0.9rem;
        display: none;
    }
    .comment-status.visible {
        display: block;
        animation: fadeIn 0.3s var(--transition-fast);
    }
    .comment-status.success {
        background: rgba(14, 165, 165, 0.15);
        border: 1px solid var(--accent-color);
        color: var(--accent-color);
    }
    .comment-status.error {
        background: rgba(220, 38, 38, 0.15);
        border: 1px solid #dc2626;
        color: #dc2626;
    }

    .comments-list {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--card-border);
    }
    .comments-empty {
        color: var(--text-muted);
        font-style: italic;
        text-align: center;
    }
    .comment-item {
        padding: 1rem;
        border: 1px solid var(--card-border);
        border-radius: var(--border-radius-md);
        margin-bottom: 1rem;
        background: var(--bg-subtle);
    }
    .comment-item header {
        display: flex;
        gap: 0.5rem;
        align-items: baseline;
        margin-bottom: 0.5rem;
        font-size: 0.85rem;
    }
    .comment-item .author {
        font-weight: 600;
        color: var(--text-color);
    }
    .comment-item .date {
        color: var(--text-muted);
        font-family: var(--font-mono);
    }
    .comment-item .message {
        color: var(--text-color);
        line-height: 1.6;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-4px);
        }
        to {
            opacity: 1;
            transform: none;
        }
    }
</style>

<script type="module" src="/scripts/comments.js" async></script>
