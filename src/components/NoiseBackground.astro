---
/**
 * NoiseBackground: A subtle SVG noise texture overlay to give
 * the application a premium, physical feel.
 */
---

<div class="noise-overlay" aria-hidden="true"></div>

<style>
	.noise-overlay {
		position: fixed;
		inset: 0;
		z-index: 9999;
		pointer-events: none;
		background-image:
			radial-gradient(circle at 30% 20%, rgba(0,0,0,0.04) 0%, transparent 25%),
			radial-gradient(circle at 70% 80%, rgba(0,0,0,0.02) 0%, transparent 30%);
		opacity: 0.05;
		mix-blend-mode: overlay;
	}

	:global(html[data-theme='dark']) .noise-overlay {
		opacity: 0.07;
		mix-blend-mode: soft-light;
	}
</style>
