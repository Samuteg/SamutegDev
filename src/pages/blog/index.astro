---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import NoiseBackground from "../../components/NoiseBackground.astro";
import "../../styles/posts.css";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.blog-header {
				padding: 3rem 0 2rem 0;
				margin-bottom: 3rem;
				border-bottom: 1px solid var(--card-border);
			}
			.blog-header h1 {
				font-size: 2.5rem;
				margin-bottom: 0.5rem;
				font-weight: 800;
				letter-spacing: -0.05em;
			}
			.blog-header .intro {
				font-size: 1.1rem;
				color: var(--text-muted);
				margin: 0;
				max-width: 600px;
			}

			.posts-list {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				margin-bottom: 4rem;
			}

			/* Blog-specific: grayscale effect on post images */
			.post-item img {
				transition: filter var(--transition-fast);
				filter: grayscale(80%) contrast(1.1);
			}

			.post-item:hover img {
				filter: grayscale(0%) contrast(1);
			}

			/* Blog-specific: clamp to 3 lines instead of 2 */
			.post-item p {
				-webkit-line-clamp: 3;
			}

			@media (max-width: 768px) {
				.blog-header {
					padding: 2rem 0;
				}
				.blog-header h1 {
					font-size: 2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<NoiseBackground />
		<main>
			<section>
				<div class="blog-header fade-in-up">
					<h1>Blog</h1>
					<p class="intro">Escritos sobre engenharia de software e design.</p>
				</div>
				<div class="posts-list">
					{
						posts.map((post, i) => (
							<a href={`/blog/${post.id}/`} class={`post-item-link fade-in-up delay-${Math.min(i + 1, 5)}`}>
								<article class="post-item">
									{post.data.heroImage && (
										<div class="image-wrapper">
											<Image width={480} height={270} src={post.data.heroImage} alt="" loading="lazy" decoding="async" style={`view-transition-name: img-${post.id}`} />
										</div>
									)}
									<div class="item-content">
										<div class="date">
											<FormattedDate date={post.data.pubDate} />
										</div>
										<h2 style={`view-transition-name: title-${post.id}`}>{post.data.title}</h2>
										<p>{post.data.description}</p>
									</div>
								</article>
							</a>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
