---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import NoiseBackground from "../components/NoiseBackground.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const posts = (await getCollection("blog"))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 4);
---

<!doctype html>
<html lang="pt-BR">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            /* ── Layout ── */
            .centered {
                max-width: 840px;
                margin: 0 auto;
                text-align: center;
            }

            /* ── Hero ── */
            .hero {
                padding: 6rem 0 5rem;
                text-align: center;
            }
            .hero h1 {
                font-size: 3rem;
                margin-bottom: 1rem;
                font-weight: 800;
                letter-spacing: -0.05em;
                line-height: 1.1;
                background: linear-gradient(
                    135deg,
                    var(--accent-color),
                    #6366f1
                );
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }
            .hero .subtitle {
                font-size: 1.15rem;
                margin: 0 0 2rem 0;
                color: var(--text-muted);
                line-height: 1.6;
            }
            .hero-buttons {
                display: flex;
                gap: 1rem;
                justify-content: center;
                flex-wrap: wrap;
            }
            .hero-stats {
                display: flex;
                justify-content: center;
                gap: 2rem;
                margin-top: 3rem;
                padding-top: 2rem;
                border-top: 1px solid var(--card-border);
                flex-wrap: wrap;
            }
            .stat-item {
                text-align: center;
                padding: 1rem;
                background: var(--bg-subtle);
                border-radius: var(--border-radius-md);
                border: 1px solid var(--card-border);
                transition: all var(--transition-fast);
            }
            .stat-item:hover {
                transform: translateY(-2px);
                box-shadow: var(--shadow-md);
                border-color: var(--accent-color);
            }
            .stat-number {
                font-size: 2rem;
                font-weight: 800;
                color: var(--accent-color);
                display: block;
                line-height: 1;
            }
            .stat-label {
                font-size: 0.9rem;
                color: var(--text-muted);
                margin-top: 0.5rem;
                display: block;
            }

            /* ── Section Title ── */
            .section-header {
                display: flex;
                align-items: baseline;
                justify-content: space-between;
                margin-bottom: 2rem;
                border-bottom: 1px solid var(--card-border);
                padding-bottom: 0.5rem;
            }
            .section-header h2 {
                margin: 0;
                font-size: 1.25rem;
                font-weight: 600;
            }
            .view-all-link {
                font-size: 0.9rem;
                font-weight: 500;
                color: var(--text-muted);
            }
            .view-all-link:hover {
                color: var(--text-color);
            }

            /* ── Posts List ── */
            .posts-list {
                display: flex;
                flex-direction: column;
                gap: 1.5rem;
                margin-bottom: 4rem;
            }
            .post-item-link {
                text-decoration: none;
                color: inherit;
                display: block;
            }
            .post-item {
                display: grid;
                grid-template-columns: 240px 1fr;
                gap: 2rem;
                padding: 1.25rem;
                border-radius: var(--border-radius-md);
                border: 1px solid transparent;
                transition: all var(--transition-fast);
                position: relative;
                overflow: hidden;
            }
            .post-item:hover {
                background: var(--card-hover-bg);
                border-color: var(--card-hover-border);
            }
            .post-item::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 4px;
                height: 100%;
                background: linear-gradient(
                    to bottom,
                    var(--accent-color),
                    transparent
                );
                opacity: 0;
                transition: opacity var(--transition-fast);
            }
            .post-item:hover::before {
                opacity: 1;
            }
            .image-wrapper {
                aspect-ratio: 16 / 9;
                width: 100%;
                border-radius: var(--border-radius-sm);
                overflow: hidden;
                border: 1px solid var(--card-border);
                background: var(--bg-subtle);
            }
            .post-item img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: 0;
                border: none;
                transition: transform var(--transition-normal);
            }
            .post-item:hover img {
                transform: scale(1.02);
            }
            .item-content {
                display: flex;
                flex-direction: column;
                justify-content: center;
            }
            .date {
                font-size: 0.85rem;
                font-weight: 500;
                color: var(--text-muted);
                margin-bottom: 0.4rem;
                font-family: var(--font-mono);
            }
            .post-item h3 {
                margin: 0 0 0.5rem 0;
                font-size: 1.2rem;
                font-weight: 600;
                line-height: 1.3;
                transition: color var(--transition-fast);
            }
            .post-item p {
                margin: 0;
                font-size: 0.95rem;
                color: var(--text-muted);
                line-height: 1.5;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }
            @media (max-width: 768px) {
                .hero {
                    padding: 4rem 0 3rem;
                }
                .hero h1 {
                    font-size: 2.25rem;
                }
                .hero-stats {
                    gap: 1rem;
                    margin-top: 2rem;
                    padding-top: 1.5rem;
                }
                .stat-item {
                    flex: 1;
                    min-width: 120px;
                }
                .post-item {
                    grid-template-columns: 1fr;
                    gap: 1rem;
                    padding: 1rem;
                }
                .image-wrapper {
                    display: none;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <NoiseBackground />
        <main>
            <div class="centered">
                <!-- Hero Section -->
                <section class="hero">
                    <h1 class="fade-in-up">SamutegDev</h1>
                    <p class="subtitle fade-in-up delay-1">
                        {SITE_DESCRIPTION}
                    </p>
                    <div class="hero-buttons fade-in-up delay-2">
                        <a href="/blog" class="btn btn-primary">Ler artigos</a>
                        <a href="/about" class="btn btn-secondary">Sobre mim</a>
                    </div>
                    <div class="hero-stats fade-in-up delay-3">
                        <div class="stat-item">
                            <span class="stat-number">4+</span>
                            <span class="stat-label">Artigos publicados</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-number">2026</span>
                            <span class="stat-label">Ano de início</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-number">100%</span>
                            <span class="stat-label">Feito com Astro</span>
                        </div>
                    </div>
                </section>

                <!-- Recent Posts -->
                <section class="posts fade-in-up delay-4">
                    <div class="section-header">
                        <h2>Artigos recentes</h2>
                        <a class="view-all-link" href="/blog">Ver todos →</a>
                    </div>

                    <div class="posts-list">
                        {
                            posts.map((post) => (
                                <a
                                    href={`/blog/${post.id}/`}
                                    class="post-item-link"
                                >
                                    <article class="post-item">
                                        {post.data.heroImage && (
                                            <div class="image-wrapper">
                                                <Image
                                                    width={480}
                                                    height={270}
                                                    src={post.data.heroImage}
                                                    alt=""
                                                    style={`view-transition-name: img-${post.id}`}
                                                />
                                            </div>
                                        )}
                                        <div class="item-content">
                                            <div class="date">
                                                <FormattedDate
                                                    date={post.data.pubDate}
                                                />
                                            </div>
                                            <h3
                                                style={`view-transition-name: title-${post.id}`}
                                            >
                                                {post.data.title}
                                            </h3>
                                            <p>{post.data.description}</p>
                                        </div>
                                    </article>
                                </a>
                            ))
                        }
                    </div>
                </section>
            </div>
        </main>
        <Footer />
    </body>
</html>
